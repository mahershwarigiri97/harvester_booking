{
  "expo": {
    "name": "harvester",
    "slug": "harvester",
    "version": "1.0.0",
    "jsEngine": "hermes",
    "newArchEnabled": true,
    "android": {
      "package": "com.baliram123giri.harvester",
      "permissions": [
        "INTERNET"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true,
            "enableSeparateBuildPerCPUArchitecture": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "54d9262c-65ff-4b4d-a38c-b3c62409aa1d"
      }
    },
    "owner": "baliram123giri"
  }
}