{
  "expo": {
    "name": "harvester",
    "slug": "harvester",
    "version": "1.0.0",
    "jsEngine": "hermes",
    "newArchEnabled": true,
    "android": {
      "package": "com.baliram123giri.harvester",
      "permissions": [
        "INTERNET"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true,
            "enableSeparateBuildPerCPUArchitecture": true
          }
        }
      ]
    ]
  }
}